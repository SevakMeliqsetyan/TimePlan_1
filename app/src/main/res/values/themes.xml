<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Базовая тема приложения -->
    <style name="Base.Theme.Samsung_Project_2" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Настройки системных баров -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Совместимость со старыми Android (API 23 и 27) -->
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>

        <!-- Настройки для полноэкранного режима -->
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>

        <!-- Цветовая палитра -->
        <item name="colorPrimary">@color/teal_accent</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/purple_accent</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="android:colorBackground">@color/background_dark</item>
    </style>

    <!-- Основная тема, которую использует Манифест -->
    <style name="Theme.Samsung_Project_2" parent="Base.Theme.Samsung_Project_2" />

    <!-- Стиль для скрытия индикатора активной кнопки в навигации (капсула) -->
    <style name="EmptyIndicator">
        <item name="android:color">@android:color/transparent</item>
        <item name="android:width">0dp</item>
        <item name="android:height">0dp</item>
    </style>

    <!-- ПЕРЕНЕСЕННЫЕ СТИЛИ ИЗ STYLES.XML -->
    <style name="CalendarDateText" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="CalendarHeaderText" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="CalendarWeekText" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

</resources>
