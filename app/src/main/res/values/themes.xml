<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- MODERN LIGHT THEME -->
    <style name="Base.Theme.Samsung_Project_2" parent="Theme.Material3.Light.NoActionBar">
        <!-- System bars -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>

        <!-- Main Palette -->
        <item name="colorPrimary">@color/modern_light_accent</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/modern_light_accent</item>
        <item name="colorSurface">@color/modern_light_card</item>
        <item name="android:colorBackground">@color/modern_light_bg</item>
        <item name="colorOnSurface">@color/modern_light_text</item>
        <item name="colorOnSurfaceVariant">@color/modern_light_text_secondary</item>
        <item name="colorOutline">@color/modern_light_divider</item>
        <item name="colorOutlineVariant">@color/modern_light_divider</item>
        <item name="colorSurfaceVariant">@color/modern_light_surface_variant</item>

        <!-- Components styling -->
        <item name="materialCardViewStyle">@style/ModernCardView</item>
        <item name="materialButtonStyle">@style/ModernButton</item>
        <item name="chipStyle">@style/ModernChip</item>
        <item name="textInputStyle">@style/ModernTextInputLayout</item>

        <!-- Calendar colors override -->
        <item name="android:dateTextAppearance">@style/CalendarDateText</item>
        <item name="android:weekDayTextAppearance">@style/CalendarWeekText</item>
    </style>

    <style name="Theme.Samsung_Project_2" parent="Base.Theme.Samsung_Project_2" />

    <!-- COMPONENT STYLES -->
    <style name="ModernCardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/modern_light_card</item>
        <item name="cardElevation">2dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.MediumComponent</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="ModernButton" parent="Widget.Material3.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.MediumComponent</item>
    </style>

    <style name="ModernChip" parent="Widget.Material3.Chip.Assist">
        <item name="chipBackgroundColor">@color/modern_light_surface_variant</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="android:textColor">@color/modern_light_text</item>
    </style>

    <style name="ModernTextInputLayout" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/modern_light_surface_variant</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- TEXT STYLES -->
    <style name="CalendarDateText" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/modern_light_text</item>
    </style>

    <style name="CalendarWeekText" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/modern_light_text_secondary</item>
    </style>

    <style name="EmptyIndicator">
        <item name="android:color">@android:color/transparent</item>
        <item name="android:width">0dp</item>
        <item name="android:height">0dp</item>
    </style>

</resources>